{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": "workers/app.ts",
  "compatibility_date": "2025-08-01",
  "compatibility_flags": ["nodejs_compat_v2"],
  "assets": {
    "directory": "build/client"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "wachiman-db",
      "database_id": "wachiman-db-id"
    }
  ],
  "observability": {
    "enabled": true
  }
}
