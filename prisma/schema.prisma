// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  ACCESS_OPERATOR
  ACCESS_MONITOR
  SECURITY_MANAGER
  ACCESS_APPROVER
  ACCESS_REQUESTER
}

model User {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  fullName  String
  username  String    @unique
  password  String
  isActive  Boolean?  @default(true)
  isTrashed Boolean?  @default(false)
  role      UserRole? @default(ACCESS_OPERATOR)

  siteId       String
  site         Site       @relation(fields: [siteId], references: [id])
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  createdAccesLogs     AccessLog[] @relation("createdBy")
  accessLogsMarkedExit AccessLog[] @relation("exitRecordedBy")

  requestedPlannedAccesses PlannedAccess[] @relation("requestedBy")
  validatedPlannedAccess   PlannedAccess[] @relation("approvedBy")

  @@index([username])
}

model Site {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  slug      String   @unique
  address   String?

  users           User[]
  accessLogs      AccessLog[]
  plannedAccesses PlannedAccess[]

  @@index([slug])
}

model Department {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  slug      String   @unique

  users User[]

  @@index([slug])
}

model AccessLog {
  id                     String    @id @default(uuid())
  entryTimestamp         DateTime
  entrySignatureEnvelope Json
  exitTimestamp          DateTime?
  exitSignatureEnvelope  Json?
  companyNameSnapshot    String
  firstNameSnapshot      String
  middleNameSnapshot     String?
  lastNameSnapshot       String
  secondLastNameSnapshot String?
  phoneNumber            String?
  legalIdSnapshot        String
  withVehicle            Boolean   @default(false)
  visitReason            String

  siteId             String
  site               Site              @relation(fields: [siteId], references: [id])
  createdById        String
  createdBy          User              @relation(name: "createdBy", fields: [createdById], references: [id])
  exitRecordedById   String?
  exitRecordedBy     User?             @relation(name: "exitRecordedBy", fields: [exitRecordedById], references: [id])
  vehicleAccessLogId String?
  vehicleAccessLog   AccessLogVehicle? @relation(fields: [vehicleAccessLogId], references: [id])

  plannedAccessId       String?
  plannedAccess         PlannedAccess?       @relation(fields: [plannedAccessId], references: [id])
  plannedAccessPersonId String?
  plannedAccessPerson   PlannedAccessPerson? @relation(fields: [plannedAccessPersonId], references: [id])

  externalWorkerId String?
  externalWorker   ExternalWorker? @relation(fields: [externalWorkerId], references: [id])
}

model Company {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  cif       String   @default("")
  address   String?
  phone     String?
  email     String?
  slug      String   @unique

  externalWorkers ExternalWorker[]
  @@index([slug])
}

model WorkCategory {
  id                        String   @id @default(uuid())
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  name                      String
  description               String?
  requiresSpecialPermission Boolean  @default(false)
  requiresTraining          Boolean  @default(false)

  externalWorkers ExternalWorker[]
}

model ExternalWorker {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName      String
  middleName     String?
  lastName       String
  secondLastName String?
  phoneNumber    String?
  legalId        String   @unique

  workCategoryId String
  workCategory   WorkCategory @relation(fields: [workCategoryId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  accessLogs          AccessLog[]
  plannedAccessPersons PlannedAccessPerson[]
  documents           WorkerDocument[]

  @@index([legalId])
  @@index([companyId])
  @@index([workCategoryId])
}

enum DocumentType {
  IDENTIFICATION
  TRAINING
}

enum DocumentStatus {
  VALIDATED
  EXPIRED
  ARCHIVED
}

model WorkerDocument {
  id        String         @id @default(uuid())
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  documentType DocumentType
  status       DocumentStatus @default(VALIDATED)

  fileName   String
  filePath   String
  fileSize   Int?
  mimeType   String?
  expiryDate DateTime

  notes String?

  externalWorkerId String
  externalWorker   ExternalWorker @relation(fields: [externalWorkerId], references: [id], onDelete: Cascade)

  @@index([externalWorkerId])
  @@index([status, expiryDate])
}

model AuditLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  entityType String
  entityId   String
  action     String
  changedBy  String
  summary    String
  metadata   Json?

  @@index([entityType, entityId])
  @@index([changedBy])
  @@index([createdAt])
}

model AccessLogVehicle {
  id            String      @id @default(uuid())
  typeSnapshot  String
  brandSnapshot String?
  modelSnapshot String?
  plateSnapshot String
  accessLogs    AccessLog[]
}

enum PlannedAccessStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CANCELED
  EXPIRED
  USED
  PARTIALLY_USED
}

model PlannedAccess {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expectedStartDatetime DateTime
  expectedEndDatetime   DateTime?
  status                PlannedAccessStatus @default(PENDING_APPROVAL)
  companySnapshot       String
  visitReason           String

  approvedAt   DateTime?
  approvedById String
  approvedBy   User      @relation(name: "approvedBy", fields: [approvedById], references: [id])

  requestedById String
  requestedBy   User   @relation(name: "requestedBy", fields: [requestedById], references: [id])

  siteId String
  site   Site   @relation(fields: [siteId], references: [id])

  plannedAccessPersons PlannedAccessPerson[]
  accessLogs           AccessLog[]

  @@index([status, siteId])
  @@index([expectedStartDatetime, expectedEndDatetime])
}

model PlannedAccessPerson {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plannedAccessId String
  plannedAccess   PlannedAccess @relation(fields: [plannedAccessId], references: [id])

  firstNameSnapshot      String
  middleNameSnapshot     String?
  lastNameSnapshot       String
  secondLastNameSnapshot String?
  phoneNumber            String?
  legalIdSnapshot        String

  accessLogs AccessLog[]

  externalWorkerId String?
  externalWorker   ExternalWorker? @relation(fields: [externalWorkerId], references: [id])

  @@index([legalIdSnapshot])
  @@index([plannedAccessId])
}
