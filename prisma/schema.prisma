// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  ADMIN
  ACCESS_REQUESTER
  ACCESS_OPERATOR
  ACCESS_APPROVER
  ACCESS_MONITOR
  SECURITY_MANAGER
}

enum AccessRequestStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  IN_PROGRESS
  COMPLETED
  EXPIRED
  CANCELLED
}

model User {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  fullName  String
  username  String    @unique
  password  String
  isActive  Boolean?  @default(true)
  isTrashed Boolean?  @default(false)
  role      UserRole? @default(ACCESS_REQUESTER)

  siteId               String
  site                 Site        @relation(fields: [siteId], references: [id])
  departmentId         String
  department           Department  @relation(fields: [departmentId], references: [id])
  createdAccesLogs     AccessLog[] @relation("createdBy")
  accessLogsMarkedExit AccessLog[] @relation("exitRecordedBy")

  @@index([username])
}

model Site {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  slug      String   @unique
  address   String?

  users      User[]
  accessLogs AccessLog[]

  @@index([slug])
}

model Department {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  slug      String   @unique

  users User[]

  @@index([slug])
}

model AccessLog {
  id                     String    @id @default(uuid())
  entryTimestamp         DateTime
  entrySignatureEnvelope Json
  exitTimestamp          DateTime?
  exitSignatureEnvelope  Json?
  companyNameSnapshot    String
  firstNameSnapshot      String
  middleNameSnapshot     String?
  lastNameSnapshot       String
  secondLastNameSnapshot String?
  phoneNumber            String?
  legalIdSnapshot        String
  withVehicle            Boolean   @default(false)
  visitReason            String

  siteId             String
  site               Site               @relation(fields: [siteId], references: [id])
  createdById        String
  createdBy          User               @relation(name: "createdBy", fields: [createdById], references: [id])
  exitRecordedById   String?
  exitRecordedBy     User?              @relation(name: "exitRecordedBy", fields: [exitRecordedById], references: [id])
  vehicleAccessLogId String?
  vehicleAccessLog   AccessLogVehicle?  @relation(fields: [vehicleAccessLogId], references: [id])
  accessRequestLogs  AccessRequestLog[]
}

model AccessLogVehicle {
  id            String      @id @default(uuid())
  typeSnapshot  String
  brandSnapshot String?
  modelSnapshot String?
  plateSnapshot String
  accessLogs    AccessLog[]
}

model AccessRequest {
  id                String              @id @default(cuid())
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  expectedStartDate DateTime
  expectedEndDate   DateTime?
  status            AccessRequestStatus @default(PENDING_APPROVAL)

  accessRequestPersons  AccessRequestPerson[]
  accessRequestVehicles AccessRequestVehicle[]
  accessRequestLogs     AccessRequestLog[]
}

model AccessRequestLog {
  id String @id @default(uuid())

  accessLogId            String
  accessLog              AccessLog            @relation(fields: [accessLogId], references: [id])
  accessRequestId        String
  accessRequest          AccessRequest        @relation(fields: [accessRequestId], references: [id])
  accessRequestPersonId  String
  accessRequestPerson    AccessRequestPerson  @relation(fields: [accessRequestPersonId], references: [id])
  accessRequestVehicleId String
  accessRequestVehicle   AccessRequestVehicle @relation(fields: [accessRequestVehicleId], references: [id])
}

model AccessRequestPerson {
  id                     String   @id @default(uuid())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  firstNameSnapshot      String
  middleNameSnapshot     String?
  lastNameSnapshot       String
  secondLastNameSnapshot String?
  legalIdSnapshot        String

  accessRequestId   String
  accessRequest     AccessRequest      @relation(fields: [accessRequestId], references: [id])
  accessRequestLogs AccessRequestLog[]
}

model AccessRequestVehicle {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  typeSnapshot  String
  brandSnapshot String?
  modelSnapshot String?
  plateSnapshot String

  accessRequestId   String
  accessRequest     AccessRequest      @relation(fields: [accessRequestId], references: [id])
  accessRequestLogs AccessRequestLog[]
}
