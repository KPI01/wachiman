// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  ADMIN
  ACCESS_REQUESTER
  ACCESS_OPERATOR
  ACCESS_APPROVER
  ACCESS_MONITOR
  SECURITY_MANAGER
}

enum PlannedAccessStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  IN_PROGRESS
  COMPLETED
  EXPIRED
  CANCELLED
}

model User {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  fullName  String
  username  String    @unique
  password  String
  isActive  Boolean?  @default(true)
  isTrashed Boolean?  @default(false)
  role      UserRole? @default(ACCESS_REQUESTER)

  siteId               String
  site                 Site        @relation(fields: [siteId], references: [id])
  departmentId         String
  department           Department  @relation(fields: [departmentId], references: [id])
  createdAccesLogs     AccessLog[] @relation("createdBy")
  accessLogsMarkedExit AccessLog[] @relation("exitRecordedBy")

  @@index([username])
}

model Site {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  slug      String   @unique
  address   String?

  users      User[]
  accessLogs AccessLog[]

  @@index([slug])
}

model Department {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  slug      String   @unique

  users User[]

  @@index([slug])
}

model AccessLog {
  id                     String    @id @default(uuid())
  entryTimestamp         DateTime
  entrySignatureEnvelope Json
  exitTimestamp          DateTime?
  exitSignatureEnvelope  Json?
  companyNameSnapshot    String
  firstNameSnapshot      String
  middleNameSnapshot     String?
  lastNameSnapshot       String
  secondLastNameSnapshot String?
  phoneNumber            String?
  legalIdSnapshot        String
  withVehicle            Boolean   @default(false)
  visitReason            String

  siteId             String
  site               Site               @relation(fields: [siteId], references: [id])
  createdById        String
  createdBy          User               @relation(name: "createdBy", fields: [createdById], references: [id])
  exitRecordedById   String?
  exitRecordedBy     User?              @relation(name: "exitRecordedBy", fields: [exitRecordedById], references: [id])
  vehicleAccessLogId String?
  vehicleAccessLog   AccessLogVehicle?  @relation(fields: [vehicleAccessLogId], references: [id])
  plannedAccessLogs  PlannedAccessLog[]
}

model AccessLogVehicle {
  id            String      @id @default(uuid())
  typeSnapshot  String
  brandSnapshot String?
  modelSnapshot String?
  plateSnapshot String
  accessLogs    AccessLog[]
}

model PlannedAccess {
  id                String              @id @default(cuid())
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  expectedStartDate DateTime
  expectedEndDate   DateTime?
  status            PlannedAccessStatus @default(PENDING_APPROVAL)

  plannedAccessPersons  PlannedAccessPerson[]
  plannedAccessVehicles PlannedAccessVehicle[]
  plannedAccessLogs     PlannedAccessLog[]
}

model PlannedAccessLog {
  id String @id @default(uuid())

  accessLogId            String
  accessLog              AccessLog            @relation(fields: [accessLogId], references: [id])
  plannedAccessId        String
  plannedAccess          PlannedAccess        @relation(fields: [plannedAccessId], references: [id])
  plannedAccessPersonId  String
  plannedAccessPerson    PlannedAccessPerson  @relation(fields: [plannedAccessPersonId], references: [id])
  plannedAccessVehicleId String
  plannedAccessVehicle   PlannedAccessVehicle @relation(fields: [plannedAccessVehicleId], references: [id])
}

model PlannedAccessPerson {
  id                     String   @id @default(uuid())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  firstNameSnapshot      String
  middleNameSnapshot     String?
  lastNameSnapshot       String
  secondLastNameSnapshot String?
  legalIdSnapshot        String

  plannedAccessId   String
  plannedAccess     PlannedAccess      @relation(fields: [plannedAccessId], references: [id])
  plannedAccessLogs PlannedAccessLog[]
}

model PlannedAccessVehicle {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  typeSnapshot  String
  brandSnapshot String?
  modelSnapshot String?
  plateSnapshot String

  plannedAccessId   String
  plannedAccess     PlannedAccess      @relation(fields: [plannedAccessId], references: [id])
  plannedAccessLogs PlannedAccessLog[]
}
