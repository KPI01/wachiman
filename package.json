{
  "name": "industrial-wachiman",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "lint": "eslint .",
    "start": "react-router-serve ./dist/server/index.js",
    "deploy": "react-router build && wrangler deploy",
    "preview": "wrangler dev",
    "cf-typegen": "wrangler types",
    "typecheck": "react-router typegen && tsc",
    "orm:generate": "pnpm prisma generate",
    "db:migrate-diff": "prisma migrate diff --from-local-d1 --to-schema prisma/schema.prisma --script",
    "db:apply-local": "wrangler d1 execute wachiman- --local --file=prisma/migrations/0001_init.sql",
    "db:apply-remote": "wrangler d1 execute wachiman --remote --file=prisma/migrations/0001_init.sql",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-populate": "tsx prisma/seed-populate.ts",
    "env:set-encryption-key": "tsx scripts/set-encryption-key.ts",
    "env:set-session-secret": "tsx scripts/set-session-secret.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/instrument-sans": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/public-sans": "^5.2.7",
    "@libsql/client": "^0.15.0",
    "@prisma/adapter-d1": "^7.7.0",
    "@prisma/adapter-libsql": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@react-router/cloudflare": "^7.14.0",
    "@react-router/node": "7.14.0",
    "@react-router/serve": "7.14.0",
    "@tanstack/react-table": "^8.21.3",
    "@types/react-grid-layout": "^2.1.0",
    "@uiw/react-signature": "^1.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "isbot": "^5.1.36",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^10.0.0",
    "react-dom": "^19.2.4",
    "react-grid-layout": "^2.2.3",
    "react-imask": "^7.6.1",
    "react-router": "7.14.0",
    "react-signature-canvas": "1.1.0-alpha.2",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1",
    "@cloudflare/workers-types": "^5.20260717.1",
    "@eslint/js": "^9.39.1",
    "@react-router/dev": "7.14.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prisma": "^7.7.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^8.0.3",
    "wrangler": "^4.112.0"
  }
}
